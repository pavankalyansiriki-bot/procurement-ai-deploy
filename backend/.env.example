# .env — Copy this to .env and fill in your values
# NEVER commit the real .env to GitHub

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used by the agent pipeline (default: gemini-2.5-flash-lite,
# which has a much higher free-tier daily quota than gemini-3.5-flash)
GEMINI_MODEL=gemini-2.5-flash-lite

# SAP CAP backend URL (default: local)
CAP_BASE_URL=http://localhost:4004

# App secret for internal auth
APP_SECRET=dev-secret-change-in-production

# Python server port
PORT=8000
