{
  "name": "procurement-cap-backend",
  "version": "1.0.0",
  "description": "SAP CAP Backend for Procurement AI Agent",
  "dependencies": {
    "@sap/cds": "^8.0.0",
    "express": "^4.18.2",
    "better-sqlite3": "^12.10.0",
    "@cap-js/sqlite": "^1.5.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8.0.0"
  },
  "overrides": {
    "better-sqlite3": "^12.10.0"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "deploy:sqlite": "cds deploy --to sqlite:procurement.db"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "procurement.db"
        }
      }
    },
    "auth": {
      "kind": "mocked",
      "users": {
        "procurement_officer": {
          "password": "pass123",
          "roles": ["ProcurementOfficer"]
        },
        "finance_manager": {
          "password": "pass123",
          "roles": ["FinanceManager"]
        },
        "budget_controller": {
          "password": "pass123",
          "roles": ["BudgetController"]
        },
        "admin": {
          "password": "admin123",
          "roles": ["ProcurementOfficer", "FinanceManager", "BudgetController"]
        }
      }
    }
  }
}
